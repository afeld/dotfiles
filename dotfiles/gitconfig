[user]
	email = aidan.feldman@gmail.com
	name = Aidan Feldman
[core]
	excludesfile = ~/.gitignore
	editor = code --wait
	autocrlf = input
	precomposeunicode = true
	ignorecase = false
[color]
	ui = true
[merge]
	conflictstyle = diff3
	keepBackup = false
	tool = custom
[pull]
	ff = only
[init]
	defaultBranch = main
[github]
	user = afeld
[alias]
	bclean = clean-branches
	branches = latest-branches
	latest = latest-tag
	lbclean = clean-local-branches
	lg = pretty-log
	fp = push --force-with-lease
	mw = merge-no-whitespace
	um = checkout-upstream-primary
	co = checkout
	cpr = create-pull-request
	feature = create-feature-branch
	s = status
  dw = diff --color-words=\"\\w+\"
	fix = commit -a --amend --no-edit
[branch]
	autosetupmerge = true
[push]
	# only push the current branch
	default = upstream
	autoSetupRemote = true
[filter "media"]
	required = true
	clean = git media clean %f
	smudge = git media smudge %f
[diff]
	compactionHeuristic = true
	noprefix = true
[credential]
	azreposCredentialType = oauth
	# supports SSO
	# https://docs.github.com/en/get-started/git-basics/caching-your-github-credentials-in-git
	# https://learn.microsoft.com/en-us/azure/devops/repos/git/set-up-credential-managers?view=azure-devops
	helper = /usr/local/share/gcm-core/git-credential-manager
[url "https://github.com"]
	insteadOf = git://github.com
[interactive]
	diffFilter = diff-highlight
[pager]
	log = diff-highlight | less
	show = diff-highlight | less
	diff = diff-highlight | less
[includeIf "gitdir:~/dev/cal-itp/"]
	path = .gitconfig-work
[credential "https://dev.azure.com"]
	useHttpPath = true
